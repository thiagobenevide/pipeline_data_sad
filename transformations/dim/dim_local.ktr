  <step>
    <name>JavaScript - Calcula Periodo</name>
    <type>ScriptValueMod</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compatible>Y</compatible>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>
// seq 0 = 20191, seq 1 = 20192, seq 2 = 20193, seq 3 = 20194, seq 4 = 20201, ...
var s = parseInt(seq);
var ano = 2019 + Math.floor(s / 4);
var trimestre = (s % 4) + 1;
var periodo = "" + ano + trimestre;

// Trimestre alvo: anterior ao atual (API disponibiliza com ~2 meses de atraso)
var d = new Date();
var curY = d.getFullYear();
var curM = d.getMonth() + 1;
var curQ = Math.ceil(curM / 3);
var tQ = curQ - 1;
var tY = curY;
if (tQ &lt; 1) { tQ = 4; tY = curY - 1; }
var periodo_alvo = "" + tY + tQ;

// manter = "S" somente se este periodo estiver dentro do intervalo valido
var manter = (periodo &lt;= periodo_alvo) ? "S" : "N";
        </jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>periodo</name>
