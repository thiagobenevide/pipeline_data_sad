  <step>
    <name>JavaScript - Add Lat Lon</name>
    <type>ScriptValueMod</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compatible>Y</compatible>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>
// Centroides geograficos (latitude/longitude) de cada estado brasileiro
var centroides = {
  "AC": { lat: "-9.0238",  lon: "-70.8120" },
  "AL": { lat: "-9.5713",  lon: "-36.7820" },
  "AM": { lat: "-3.4168",  lon: "-65.8561" },
  "AP": { lat: "1.4102",   lon: "-51.7703" },
  "BA": { lat: "-12.5797", lon: "-41.7007" },
  "CE": { lat: "-5.4984",  lon: "-39.3206" },
  "DF": { lat: "-15.7801", lon: "-47.9292" },
  "ES": { lat: "-19.1834", lon: "-40.3089" },
  "GO": { lat: "-15.8270", lon: "-49.8362" },
  "MA": { lat: "-5.4220",  lon: "-45.4426" },
  "MG": { lat: "-18.5122", lon: "-44.5550" },
  "MS": { lat: "-20.7722", lon: "-54.7852" },
  "MT": { lat: "-12.6819", lon: "-56.9211" },
  "PA": { lat: "-3.4168",  lon: "-52.2111" },
  "PB": { lat: "-7.2399",  lon: "-36.7819" },
  "PE": { lat: "-8.8137",  lon: "-36.9541" },
  "PI": { lat: "-7.7183",  lon: "-42.7289" },
  "PR": { lat: "-25.2521", lon: "-52.0215" },
  "RJ": { lat: "-22.9035", lon: "-43.1724" },
  "RN": { lat: "-5.8127",  lon: "-36.2492" },
  "RO": { lat: "-10.9161", lon: "-62.0775" },
  "RR": { lat: "1.9900",   lon: "-61.3300" },
  "RS": { lat: "-30.0346", lon: "-51.2177" },
  "SC": { lat: "-27.2423", lon: "-50.2189" },
  "SE": { lat: "-10.5741", lon: "-37.3857" },
  "SP": { lat: "-22.9099", lon: "-48.2020" },
  "TO": { lat: "-10.1753", lon: "-48.2982" }
};

var sigla = ibge_sigla + "";
var centroide = centroides[sigla];
var loc_latidude  = centroide ? centroide.lat : "0";
var loc_longitude = centroide ? centroide.lon : "0";
        </jsScript_script>
      </jsScript>
    </jsScripts>
