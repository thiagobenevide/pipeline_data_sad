        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>
var uf = uf_terminal + "";
var url_ibge = "https://servicodados.ibge.gov.br/api/v1/localidades/estados/" + uf;
        </jsScript_script>
      </jsScript>
    </jsScripts>
