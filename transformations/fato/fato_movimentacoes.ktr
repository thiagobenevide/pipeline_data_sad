      <formula_string>INT(MOD([id]-1; 4))+1</formula_string>
      <value_type>Integer</value_type>
      <value_length>-1</value_length>
      <value_precision>-1</value_precision>
      <replace_field/>
    </formula>
    <formula>
      <field_name>temp_fim_trimestre_estimado</field_name>
      <formula_string>DATE(YEAR([data])+INT(([id]-1)/4);(INT(MOD([id]-1;4))+1)*3;IF(MOD(INT(MOD([id]-1;4))+1;2)=1;31;30))</formula_string>
      <value_type>Date</value_type>
      <value_length>-1</value_length>
      <value_precision>-1</value_precision>
      <replace_field/>
    </formula>
