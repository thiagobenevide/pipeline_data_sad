  <step>
    <name>Table Input - Gera Periodos</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>Banco SAD</connection>
    <sql>WITH limpa AS (
  DELETE FROM dm_financeiro.fato_transacoes
  WHERE '${TRIMESTRE}' = ''
     OR tra_sk_tempo IN (
          SELECT tempo_sk
          FROM dm_financeiro.dim_tempo
          WHERE temp_ano_trimestre = '${TRIMESTRE}'
        )
)
SELECT gs AS seq
FROM generate_series(0, 59) gs
WHERE '${TRIMESTRE}' = ''
   OR concat(2019 + gs/4, (gs % 4) + 1)::text = '${TRIMESTRE}'</sql>
    <limit>0</limit>
